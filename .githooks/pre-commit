#!/bin/bash

# AutoVPN 版本自动递增脚本
# 每次 commit 前自动更新 cf_worker_relay.js 中的 VERSION

WORKER_FILE="cf_worker_relay.js"

if [ -f "$WORKER_FILE" ]; then
    # 读取当前版本号
    current_version=$(grep '^const VERSION = "v' "$WORKER_FILE" | head -1 | cut -d'"' -f2)
    
    if [ -n "$current_version" ]; then
        # 解析版本号各部分
        version=${current_version#v}
        major=$(echo $version | cut -d. -f1)
        minor=$(echo $version | cut -d. -f2)
        patch=$(echo $version | cut -d. -f3)
        
        # 递增 patch 版本号
        new_patch=$((patch + 1))
        new_version="v${major}.${minor}.${new_patch}"
        
        # 更新文件中的版本号
        sed -i.bak "s/^const VERSION = \"v.*\";/const VERSION = \"${new_version}\";/" "$WORKER_FILE"
        rm -f "$WORKER_FILE.bak"
        
        echo "📌 版本号已更新：$current_version -> $new_version"
        
        # 自动添加到暂存区
        git add "$WORKER_FILE"
    else
        echo "⚠️  未找到 VERSION 常量，跳过版本更新"
    fi
else
    echo "⚠️  未找到 $WORKER_FILE，跳过版本更新"
fi
